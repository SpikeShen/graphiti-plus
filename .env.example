OPENAI_API_KEY=

# Neo4j database connection
NEO4J_URI=bolt://localhost:7687
NEO4J_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# FalkorDB database connection
FALKORDB_URI=
FALKORDB_PORT=
FALKORDB_USER=
FALKORDB_PASSWORD=

# AWS / Bedrock
AWS_REGION=us-east-1
BEDROCK_MODEL=moonshotai.kimi-k2.5
BEDROCK_EMBEDDING_MODEL=amazon.nova-2-multimodal-embeddings-v1:0
BEDROCK_EMBEDDING_DIM=1024
LLM_TEMPERATURE=0.1

# S3 Vectors
S3_VECTORS_BUCKET=graphiti-vectors-poc

# Search
SEARCH_LIMIT=10
DEEP_SEARCH_LIMIT=20

USE_PARALLEL_RUNTIME=
SEMAPHORE_LIMIT=
GITHUB_SHA=
MAX_REFLEXION_ITERATIONS=
ANTHROPIC_API_KEY=

# S3 Invocation Logger (optional — logs LLM/embedding calls to S3 for Athena)
# S3_LOG_ENABLED=true
# S3_LOG_BUCKET=spike-graphiti-logs
# S3_LOG_PREFIX=GraphitiLogs
# S3_LOG_FLUSH_THRESHOLD=50
# S3_LOG_PREVIEW_CHARS=200
